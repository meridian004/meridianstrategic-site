---
import Base from "../layouts/Base.astro";

const title = "Privacy Policy";
const description =
  "Meridian Strategic privacy policy. How we collect, use, and protect your information.";
---

<Base title={title} description={description}>
  <section class="bg-(--color-bg) border-b border-(--color-line)">
    <div class="max-w-3xl mx-auto px-6 pt-24 pb-32 md:pt-32 md:pb-40">
      <p class="eyebrow mb-4">Legal</p>
      <h1 class="font-serif text-4xl md:text-5xl leading-[1.08] text-(--color-ink) font-light mb-12">
        Privacy Policy
      </h1>

      <div class="space-y-8 text-(--color-ink-muted) leading-relaxed font-serif">
        <p class="text-sm text-(--color-ink-faint)">Effective date: April 2026</p>

        <div>
          <h2 class="font-serif text-xl text-(--color-ink) font-light mb-3">Overview</h2>
          <p>
            Meridian Strategic ("we," "us") respects your privacy. This policy describes
            what information we collect through meridianstrategic.io and how we use it.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-xl text-(--color-ink) font-light mb-3">Information we collect</h2>
          <p>
            When you use our contact form, we collect the information you provide: your name,
            email address, company, and message content. We do not use third-party analytics
            trackers or advertising cookies.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-xl text-(--color-ink) font-light mb-3">How we use your information</h2>
          <p>
            We use the information you submit solely to respond to your inquiry and, if mutually
            agreed, to provide advisory services. We do not sell, rent, or share your personal
            information with third parties for marketing purposes.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-xl text-(--color-ink) font-light mb-3">Data retention</h2>
          <p>
            We retain inquiry data for the duration of our business relationship and for a
            reasonable period afterward for recordkeeping. You may request deletion of your
            data at any time by contacting us.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-xl text-(--color-ink) font-light mb-3">Cookies and tracking</h2>
          <p>
            This website does not use analytics cookies, advertising trackers, or third-party
            tracking scripts. We use essential functionality only: font loading via Google Fonts
            and form processing via FormSubmit.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-xl text-(--color-ink) font-light mb-3">Contact</h2>
          <p>
            For questions about this policy or to request data deletion, contact us at
            <a href="mailto:wes@meridianstrategic.io" class="text-(--color-forest) hover:text-(--color-brass) transition-colors">
              wes@meridianstrategic.io</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>

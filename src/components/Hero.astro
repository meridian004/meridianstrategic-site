---
// Hero — dark editorial, serif headline, advisory-grade.
// Reference: McKinsey (dark navy + serif over photo) / PwC (dark bg + ITC Charter).
// Photo layer ready — swap background-image when editorial photography is sourced.
---

<section class="relative overflow-hidden border-b border-(--color-line)">
  <!-- Dark atmospheric background with editorial photography -->
  <div class="absolute inset-0" aria-hidden="true">
    <!-- Photo layer: dark forest canopy aerial (Unsplash, Edgar.infocus) -->
    <!-- Self-host: download from unsplash.com/photos/Y7gS6R8hPLg to /public/hero.jpg -->
    <div class="absolute inset-0" style="background-image: url('https://images.unsplash.com/photo-1761835454512-07185e83f2a4?w=1920&q=75&auto=format&fit=crop'); background-size: cover; background-position: center 40%;"></div>
    <!-- Forest tint overlay: unifies photo with brand palette -->
    <div class="absolute inset-0" style="background: linear-gradient(165deg, rgba(12,31,26,0.88) 0%, rgba(17,43,35,0.82) 35%, rgba(14,26,22,0.86) 70%, rgba(10,17,14,0.92) 100%);"></div>
    <!-- Grain texture overlay -->
    <div class="absolute inset-0 grain opacity-30"></div>
    <!-- Brass meridian line -->
    <div class="absolute left-0 right-0" style="top: 68%; height: 1px; background: linear-gradient(90deg, transparent, rgba(168,123,60,0.25) 20%, rgba(168,123,60,0.35) 50%, rgba(168,123,60,0.25) 80%, transparent);"></div>
  </div>

  <!-- Content -->
  <div class="relative max-w-[1280px] mx-auto px-6 pt-32 pb-36 md:pt-44 md:pb-52">
    <div data-reveal class="flex items-center gap-3 mb-12">
      <span class="w-10 h-px bg-(--color-brass)"></span>
      <p class="text-[12px] font-sans font-medium tracking-[0.12em] uppercase text-(--color-brass)">
        Strategic advisory for the disclosure era
      </p>
    </div>

    <h1
      data-reveal
      class="font-serif max-w-4xl mb-8"
      style="font-size: var(--text-hero); line-height: 1.05; letter-spacing: -0.02em; font-weight: 400; color: var(--color-ivory);"
    >
      Sustainability strategy meets disclosure compliance.
      <span class="italic" style="color: var(--color-brass);">We handle both.</span>
    </h1>

    <div data-reveal class="mt-12 grid grid-cols-1 md:grid-cols-12 gap-8 items-start">
      <p class="md:col-span-7 text-lg md:text-xl leading-relaxed font-sans max-w-2xl" style="color: rgba(249,244,232,0.72);">
        Meridian advises boards, general counsel, and sustainability leaders on the disclosure, policy, and strategy work that now shapes enterprise value. We treat sustainability as a discipline, not a compliance checkbox.
      </p>
      <div class="md:col-span-5 flex flex-col gap-3 md:pt-0">
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-5 py-3 bg-(--color-ivory) text-(--color-forest-dark) text-sm font-medium hover:bg-white transition-colors"
          style="transition: all 120ms cubic-bezier(0.25, 0.46, 0.45, 0.94);"
        >
          Begin engagement
        </a>
        <a
          href="#capabilities"
          class="inline-flex items-center justify-center px-5 py-3 border text-sm font-medium transition-colors"
          style="border-color: rgba(249,244,232,0.25); color: var(--color-ivory); transition: all 120ms cubic-bezier(0.25, 0.46, 0.45, 0.94);"
          onmouseover="this.style.borderColor='rgba(249,244,232,0.5)'"
          onmouseout="this.style.borderColor='rgba(249,244,232,0.25)'"
        >
          Our approach
        </a>
      </div>
    </div>

    <!-- Framework ribbon -->
    <div data-reveal class="mt-24 md:mt-32 pt-8 flex flex-wrap items-baseline gap-x-6 gap-y-2 text-sm" style="border-top: 1px solid rgba(249,244,232,0.12);">
      <span class="text-[12px] font-sans font-medium tracking-[0.12em] uppercase" style="color: rgba(249,244,232,0.4);">Core frameworks</span>
      <span class="font-mono text-xs tracking-tight" style="color: rgba(249,244,232,0.55);">CSRD</span>
      <span class="font-mono text-xs tracking-tight" style="color: rgba(249,244,232,0.55);">ISSB</span>
      <span class="font-mono text-xs tracking-tight" style="color: rgba(249,244,232,0.55);">TCFD</span>
      <span class="font-mono text-xs tracking-tight" style="color: rgba(249,244,232,0.55);">SASB</span>
      <span class="font-mono text-xs tracking-tight" style="color: rgba(249,244,232,0.55);">GRI</span>
      <span class="font-mono text-xs tracking-tight" style="color: rgba(249,244,232,0.55);">SEC Climate</span>
    </div>
  </div>
</section>

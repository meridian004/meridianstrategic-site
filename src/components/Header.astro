---
import Logo from "./Logo.astro";

const nav = [
  { href: "#capabilities", label: "Capabilities" },
  { href: "#representation", label: "Representation" },
  { href: "#approach", label: "Approach" },
  { href: "#insights", label: "Insights" },
];
---

<header class="border-b border-(--color-line) bg-(--color-bg)/92 backdrop-blur-sm sticky top-0 z-40">
  <div class="max-w-[1280px] mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Brand + tagline -->
    <div class="flex items-baseline gap-3 group">
      <a href="/" aria-label="Meridian Strategic — home" class="flex-shrink-0">
        <Logo size="sm" />
      </a>
      <span class="hidden sm:block text-xs text-(--color-ink-muted) font-light tracking-tight">
        Strategic advisory for the disclosure era
      </span>
    </div>

    <!-- Primary nav + CTA -->
    <nav aria-label="Primary" class="hidden md:flex items-center gap-6 text-sm">
      {nav.map((item) => (
        <a
          href={item.href}
          class="text-(--color-ink-muted) hover:text-(--color-ink) transition-colors duration-120 font-medium"
          style="transition: color 120ms cubic-bezier(0.25, 0.46, 0.45, 0.94);"
        >
          {item.label}
        </a>
      ))}
      <div class="h-4 w-px bg-(--color-line)"></div>
      <a
        href="#contact"
        class="px-4 py-2 rounded-sm bg-(--color-forest) text-(--color-ivory) text-xs font-medium hover:bg-(--color-forest-dark) transition-colors duration-120"
        style="transition: all 120ms cubic-bezier(0.25, 0.46, 0.45, 0.94);"
      >
        Contact
      </a>
    </nav>

    <!-- Mobile contact -->
    <a href="#contact" class="md:hidden text-xs font-medium text-(--color-forest)">Contact</a>
  </div>
</header>

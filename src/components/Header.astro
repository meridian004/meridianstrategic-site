---
import Logo from "./Logo.astro";

const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "";
const prefix = isHome ? "" : "/";

const nav = [
  { href: `${prefix}#capabilities`, label: "Capabilities" },
  { href: `${prefix}#representation`, label: "Representation" },
  { href: `${prefix}#approach`, label: "Approach" },
  { href: `${prefix}#insights`, label: "Insights" },
];
---

<header class="border-b border-(--color-line) bg-(--color-bg)/92 backdrop-blur-sm sticky top-0 z-40">
  <div class="max-w-[1280px] mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" aria-label="Meridian Strategic - home" class="flex-shrink-0">
      <Logo size="sm" />
    </a>

    <!-- Primary nav + CTA — sans, 15px, weight 400 -->
    <nav aria-label="Primary" class="hidden md:flex items-center gap-7 font-sans">
      {nav.map((item) => (
        <a
          href={item.href}
          class="text-[15px] text-(--color-ink-muted) hover:text-(--color-ink) transition-colors font-normal"
          style="transition: color 120ms cubic-bezier(0.25, 0.46, 0.45, 0.94);"
        >
          {item.label}
        </a>
      ))}
      <div class="h-4 w-px bg-(--color-line)"></div>
      <a
        href="/contact"
        class="px-5 py-2 bg-(--color-forest) text-(--color-ivory) text-[13px] font-medium hover:bg-(--color-forest-dark) transition-colors"
        style="transition: all 120ms cubic-bezier(0.25, 0.46, 0.45, 0.94);"
      >
        Contact
      </a>
    </nav>

    <!-- Mobile contact -->
    <a href="/contact" class="md:hidden text-[13px] font-medium text-(--color-forest)">Contact</a>
  </div>
</header>

---
// Insights teaser — populated from content/insights when MDX is wired up.
// For v1, hand-authored featured pieces so the home page reads as a real firm.
const articles = [
  {
    eyebrow: "Disclosure",
    title: "What CSRD Actually Requires: A CFO's Orientation",
    dek: "A practical read of the European directive for U.S. leaders whose subsidiaries fall in scope. What's new, what's borrowed, and where the reporting pain truly lives.",
    read: "9 min read",
    date: "March 2026",
  },
  {
    eyebrow: "Policy",
    title: "The SEC Climate Rule in 2026: Where We Are, Where We're Going",
    dek: "A status read of the Commission's climate disclosure rule and its practical implications for issuers, including the interaction with California SB 253 and SB 261.",
    read: "12 min read",
    date: "February 2026",
  },
  {
    eyebrow: "Strategy",
    title: "Beyond the Report: Integrating Sustainability into Capital Allocation",
    dek: "Why sustainability strategy that lives outside the CFO's office rarely outlasts the officer who sponsored it, and how to build integration that does.",
    read: "7 min read",
    date: "January 2026",
  },
];
---

<section id="insights" class="bg-(--color-bg) border-b border-(--color-line) scroll-mt-16">
  <div class="max-w-[1280px] mx-auto px-6 py-32 md:py-40">
    <div class="flex flex-col md:flex-row md:items-start justify-between gap-8 mb-20" data-reveal>
      <div class="flex-1">
        <p class="eyebrow mb-4">Research + Insights</p>
        <h2 class="font-serif text-(--color-ink)" style="font-size: var(--text-display); line-height: 1.05; letter-spacing: var(--tracking-display); max-width: 28rem; font-weight: 400;">
          Writing shaped by the room.
        </h2>
      </div>
      <a
        href="mailto:wes@meridianstrategic.io?subject=Meridian%20Strategic%20%E2%80%94%20research%20request"
        class="text-sm text-(--color-forest) font-medium hover:text-(--color-brass) transition-colors duration-120 flex items-center gap-2 shrink-0 pt-1"
        style="transition: color 120ms cubic-bezier(0.25, 0.46, 0.45, 0.94);"
      >
        Request research
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {articles.map((a, i) => (
        <article
          data-reveal
          class="group flex flex-col bg-(--color-ivory) border border-(--color-line) p-6 hover:border-(--color-forest) hover:bg-(--color-surface) transition-all duration-120"
          style="transition: all 120ms cubic-bezier(0.25, 0.46, 0.45, 0.94);"
        >
          <div class="flex items-start justify-between gap-3 mb-4 pb-4 border-b border-(--color-line)">
            <span class="eyebrow text-xs">{a.eyebrow}</span>
            <span class="font-sans text-xs text-(--color-ink-faint) shrink-0">
              {String(i + 1).padStart(2, "0")}
            </span>
          </div>
          <h3 class="font-sans text-lg text-(--color-ink) leading-tight mb-3 group-hover:text-(--color-forest) transition-colors duration-120 font-light" style="transition: color 120ms cubic-bezier(0.25, 0.46, 0.45, 0.94);">
            {a.title}
          </h3>
          <p class="text-xs text-(--color-ink-muted) leading-relaxed mb-6 flex-1 font-serif">{a.dek}</p>
          <div class="pt-4 border-t border-(--color-line) flex items-center justify-between text-xs text-(--color-ink-faint) font-sans uppercase tracking-tight">
            <span>{a.date}</span>
            <span>{a.read}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

---
// Meridian Strategic — logo system (v2, tech-minimal)
//
// Mark: an asymmetric precision-instrument mark.
//  - A vertical meridian bar (forest) — semantically correct (a meridian is
//    a vertical line of longitude, not horizontal as in v1).
//  - A short horizon tick extending right from the meridian's midpoint
//    (brass) — the observer's bearing at the intersection.
//  - A small hollow circle at the intersection — the point of reference.
//
// Wordmark: Inter at tight tracking for "Meridian" (primary), small-caps
// Inter for "STRATEGIC" below with brass separator.

interface Props {
  variant?: "default" | "inverse" | "stacked" | "mark-only";
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { variant = "default", size = "md", class: className = "" } = Astro.props;

const markSize = size === "sm" ? 22 : size === "lg" ? 44 : 30;
const wordmarkClass = size === "sm" ? "text-base" : size === "lg" ? "text-2xl" : "text-xl";

const inkColor =
  variant === "inverse" ? "var(--color-ivory)" : "var(--color-ink)";
const brassColor = "var(--color-brass)";
const mutedColor =
  variant === "inverse" ? "rgba(249,244,232,0.62)" : "var(--color-ink-muted)";

// Shared mark render as a snippet-like function — keeps SVG geometry in one place
const markStroke = variant === "inverse" ? "var(--color-ivory)" : "var(--color-forest)";
---

{variant === "stacked" ? (
  <div class={`inline-flex flex-col items-center gap-3 ${className}`}>
    <svg width={markSize * 2} height={markSize * 2} viewBox="0 0 32 32" aria-hidden="true" class="shrink-0">
      {/* Vertical meridian bar */}
      <line x1="12" y1="3" x2="12" y2="29" stroke={markStroke} stroke-width="2.25" stroke-linecap="square" />
      {/* Horizon tick extending right from midpoint */}
      <line x1="12" y1="16" x2="26" y2="16" stroke={brassColor} stroke-width="1.5" stroke-linecap="round" />
      {/* Point of reference */}
      <circle cx="12" cy="16" r="2.25" fill="none" stroke={brassColor} stroke-width="1.25" />
    </svg>
    <div class="flex flex-col items-center">
      <span class="font-sans font-medium tracking-[-0.02em]" style={`font-size: ${markSize * 1.05}px; color: ${inkColor}; line-height: 1;`}>
        Meridian
      </span>
      <span class="font-sans text-[11px] font-medium tracking-[0.32em] mt-2 uppercase" style={`color: ${mutedColor};`}>
        Strategic
      </span>
    </div>
  </div>
) : variant === "mark-only" ? (
  <svg width={markSize} height={markSize} viewBox="0 0 32 32" aria-label="Meridian Strategic" class={`shrink-0 ${className}`}>
    <line x1="12" y1="3" x2="12" y2="29" stroke={markStroke} stroke-width="2.5" stroke-linecap="square" />
    <line x1="12" y1="16" x2="26" y2="16" stroke={brassColor} stroke-width="1.75" stroke-linecap="round" />
    <circle cx="12" cy="16" r="2.25" fill="none" stroke={brassColor} stroke-width="1.5" />
  </svg>
) : (
  <div class={`inline-flex items-center gap-3 ${className}`}>
    <svg width={markSize} height={markSize} viewBox="0 0 32 32" aria-hidden="true" class="shrink-0">
      <line x1="12" y1="3" x2="12" y2="29" stroke={markStroke} stroke-width="2.25" stroke-linecap="square" />
      <line x1="12" y1="16" x2="26" y2="16" stroke={brassColor} stroke-width="1.5" stroke-linecap="round" />
      <circle cx="12" cy="16" r="2.25" fill="none" stroke={brassColor} stroke-width="1.25" />
    </svg>
    <div class="flex flex-col leading-none">
      <span class={`font-sans font-medium tracking-[-0.015em] ${wordmarkClass}`} style={`color: ${inkColor};`}>
        Meridian
      </span>
      <span class="font-sans text-[10px] font-medium tracking-[0.32em] mt-1.5 uppercase" style={`color: ${mutedColor};`}>
        Strategic
      </span>
    </div>
  </div>
)}

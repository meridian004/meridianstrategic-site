---
// Meridian Strategic — logo system (v4, disc + waterline)
//
// Mark: a solid disc with a flowing waterline passing through.
//   - Solid disc: mass, presence, the body being measured.
//   - Brass wave crossing the disc at lower third, extending beyond:
//     the meridian as water, flow, a reference that exists past the frame.
//
// Wordmark: Source Serif 4 (the site's voice font) at weight 400.
// "STRATEGIC" in sans caps, tighter tracking (advisory-grade, not decorative).
//
// Matches the McKinsey/PwC advisory playbook: serif for voice, sans for system.

interface Props {
  variant?: "default" | "inverse" | "stacked" | "mark-only";
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { variant = "default", size = "md", class: className = "" } = Astro.props;

const markSize = size === "sm" ? 22 : size === "lg" ? 44 : 30;

const inkColor =
  variant === "inverse" ? "var(--color-ivory)" : "var(--color-ink)";
const brassColor = "var(--color-brass)";
const mutedColor =
  variant === "inverse" ? "rgba(249,244,232,0.55)" : "var(--color-ink-muted)";
const discFill =
  variant === "inverse" ? "var(--color-ivory)" : "var(--color-forest)";

// Wordmark sizing — serif, weight 400 (advisory, not bold)
const nameSize = size === "sm" ? "17px" : size === "lg" ? "28px" : "22px";
const descSize = size === "sm" ? "9px" : size === "lg" ? "11px" : "10px";
---

{variant === "stacked" ? (
  <div class={`inline-flex flex-col items-center gap-4 ${className}`}>
    <svg width={markSize * 2} height={markSize * 2} viewBox="0 0 32 32" aria-hidden="true" class="shrink-0">
      <circle cx="16" cy="16" r="11" fill={discFill} />
      <path d="M 4 20 Q 10 17, 16 20 T 28 20" fill="none" stroke={brassColor} stroke-width="1.75" stroke-linecap="round" />
    </svg>
    <div class="flex flex-col items-center">
      <span class="font-serif" style={`font-size: ${Number(nameSize.replace('px','')) * 1.3}px; font-weight: 400; letter-spacing: -0.015em; color: ${inkColor}; line-height: 1;`}>
        Meridian
      </span>
      <span class="font-sans uppercase" style={`font-size: ${descSize}; font-weight: 500; letter-spacing: 0.15em; margin-top: 8px; color: ${mutedColor};`}>
        Strategic
      </span>
    </div>
  </div>
) : variant === "mark-only" ? (
  <svg width={markSize} height={markSize} viewBox="0 0 32 32" aria-label="Meridian Strategic" class={`shrink-0 ${className}`}>
    <circle cx="16" cy="16" r="11" fill={discFill} />
    <path d="M 4 20 Q 10 17, 16 20 T 28 20" fill="none" stroke={brassColor} stroke-width="2" stroke-linecap="round" />
  </svg>
) : (
  <div class={`inline-flex items-center gap-3 ${className}`}>
    <svg width={markSize} height={markSize} viewBox="0 0 32 32" aria-hidden="true" class="shrink-0">
      <circle cx="16" cy="16" r="11" fill={discFill} />
      <path d="M 4 20 Q 10 17, 16 20 T 28 20" fill="none" stroke={brassColor} stroke-width="1.75" stroke-linecap="round" />
    </svg>
    <div class="flex flex-col leading-none">
      <span class="font-serif" style={`font-size: ${nameSize}; font-weight: 400; letter-spacing: -0.015em; color: ${inkColor}; line-height: 1;`}>
        Meridian
      </span>
      <span class="font-sans uppercase" style={`font-size: ${descSize}; font-weight: 500; letter-spacing: 0.15em; margin-top: 5px; color: ${mutedColor};`}>
        Strategic
      </span>
    </div>
  </div>
)}

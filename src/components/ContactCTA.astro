<section id="contact" class="bg-(--color-ivory) scroll-mt-16">
  <div class="max-w-[1280px] mx-auto px-6 py-28 md:py-40 text-center" data-reveal>
    <p class="eyebrow mb-6">Begin</p>
    <h2 class="font-serif text-4xl md:text-6xl leading-[1.05] text-(--color-ink) max-w-4xl mx-auto" style="font-weight: 400;">
      If ESG is on the agenda this year, we should be part of the conversation <span class="italic text-(--color-forest)">before</span> it starts.
    </h2>
    <p class="mt-8 text-xl text-(--color-ink-muted) max-w-2xl mx-auto leading-relaxed prose-editorial">
      An initial conversation is 45 minutes, confidential, and at no cost. You
      leave with a point of view on your situation, engagement or not.
    </p>

    <div class="mt-12 flex flex-col sm:flex-row justify-center gap-4">
      <a
        href="/contact"
        class="inline-flex items-center justify-center px-8 py-4 bg-(--color-forest) text-(--color-ivory) font-medium hover:bg-(--color-forest-dark) transition-colors"
      >
        Schedule a conversation
      </a>
      <a
        href="#insights"
        class="inline-flex items-center justify-center px-8 py-4 border border-(--color-line-strong) text-(--color-ink) font-medium hover:border-(--color-ink) transition-colors"
      >
        Read our writing first
      </a>
    </div>

    <p class="mt-12 text-sm text-(--color-ink-faint) font-sans uppercase tracking-[0.12em]">
      wes@meridianstrategic.io
    </p>
  </div>
</section>
